<Window x:Class="WinEventMonitor.Tray.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Windows Event Monitor"
        Width="1400" Height="860"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Icon="">

    <Grid>
        <!-- Panel de error (visible cuando el servicio no responde) -->
        <Grid x:Name="ErrorPanel" Visibility="Collapsed"
              Background="#1e293b">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">
                <TextBlock Text="🔴" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="El servicio no está disponible"
                           FontSize="20" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock x:Name="ErrorDetail"
                           FontSize="13" Foreground="#94a3b8"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           TextWrapping="Wrap" Margin="0,0,0,24"/>
                <Button x:Name="RetryButton" Content="↺  Reintentar"
                        Click="RetryButton_Click"
                        Padding="20,8" FontSize="14"
                        HorizontalAlignment="Center"
                        Background="#3b82f6" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- WebView2: la UI React completa -->
        <wv2:WebView2 x:Name="WebView" Visibility="Collapsed"/>
    </Grid>
</Window>
